# ── MLflow ────────────────────────────────────────────────────────────────────
# URI that the API and Streamlit containers use to reach the tracking server.
# When running via docker-compose, keep the default (service name + port).
# Override with a remote URI when pointing at a hosted MLflow instance.
MLFLOW_TRACKING_URI=http://mlflow:5000

# Name of the registered model in the MLflow Model Registry.
MLFLOW_MODEL_NAME=automl_model

# ── Grafana ───────────────────────────────────────────────────────────────────
# Password for the Grafana admin account (default: admin — change in production).
GRAFANA_PASSWORD=admin

# ── Automated Retraining Scheduler ───────────────────────────────────────────
# Interval in hours between scheduled retraining runs (0 = disabled).
RETRAIN_INTERVAL_HOURS=24

# Minimum F1 / R² improvement required before auto-promoting the new model.
# Set to 0 to always promote, or 1 to never auto-promote.
RETRAIN_IMPROVEMENT_THRESHOLD=0.01

# Whether to automatically promote a better model to "Production" in the registry.
# Set to "true" or "false".
RETRAIN_AUTO_PROMOTE=true

# ── API ───────────────────────────────────────────────────────────────────────
# Number of Uvicorn worker processes (override the Dockerfile default of 2).
# WEB_CONCURRENCY=2
